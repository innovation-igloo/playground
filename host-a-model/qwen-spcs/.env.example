# =============================================================================
# qwen-spcs — Environment Configuration
# =============================================================================
# Copy this file to .env and edit values for your environment.
# Everything in the stack (setup.sql, create_service.sql files, Makefile)
# reads from .env — this is the single source of truth.
# =============================================================================

# ── Snowflake connection
SNOW_CONNECTION=innovation-igloo
SNOWFLAKE_USER=YOUR_SNOWFLAKE_USERNAME

# ── Shared identifiers (role, database, schema, warehouse)
SNOWFLAKE_ROLE=QWEN_POC_ROLE
SNOWFLAKE_DATABASE=INNOVATION_IGLOO
SNOWFLAKE_SCHEMA=QWEN_OPUS_DIST
SNOWFLAKE_WAREHOUSE=QWEN_WH
WH_SIZE=X-SMALL
WH_AUTO_SUSPEND=60

# ── Qwen vLLM service (GPU)
QWEN_POOL_NAME=QWEN_GPU_POOL
QWEN_POOL_INSTANCE=GPU_NV_M
QWEN_POOL_MIN_NODES=1
QWEN_POOL_MAX_NODES=1
QWEN_POOL_AUTO_SUSPEND=3600
QWEN_IMAGE_REPO_NAME=QWEN_REPO
QWEN_IMAGE_NAME=vllm-qwen
QWEN_IMAGE_TAG=v1
QWEN_STAGE_NAME=MODEL_WEIGHTS_STAGE
QWEN_SERVICE_NAME=QWEN_INFERENCE_SERVICE

# ── Agent CPU service (LangGraph + React UI)
AGENT_POOL_NAME=AGENT_CPU_POOL
AGENT_POOL_INSTANCE=CPU_X64_S
AGENT_REPO_NAME=AGENT_REPO
AGENT_IMAGE_NAME=market-intel-agent
AGENT_IMAGE_TAG=latest
AGENT_STAGE_NAME=AGENT_STAGE
AGENT_SECRET_NAME=AGENT_PAT
AGENT_SERVICE_NAME=MARKET_INTEL_AGENT_SERVICE
